# Copy to .env.local for local dev. For GitHub Actions, add as repository secrets
# and map them in deploy.yml on the "Build React SPA" step (VITE_* are inlined at build time).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
